{
  "runtime": {
    "platform": "avocado-raspberrypi5",
    "architecture": "arm64",
    "provision_default": "img",
    "update_strategy": "mbr-ab"
  },
  "update": {
    "slot_detection": {
      "type": "uboot-env",
      "var": "avocado_boot_slot"
    },
    "os_artifacts": {
      "boot": {
        "image_key": "boot",
        "slot_partitions": [
          "boot-a",
          "boot-b"
        ]
      },
      "rootfs": {
        "image_key": "rootfs",
        "slot_partitions": [
          "rootfs-a",
          "rootfs-b"
        ]
      }
    },
    "activate": [
      {
        "type": "uboot-env",
        "set": {
          "avocado_boot_slot": "{inactive_slot}",
          "{inactive_slot}.avocado_platform": "{platform}",
          "{inactive_slot}.avocado_architecture": "{architecture}"
        }
      },
      {
        "type": "mbr-switch",
        "devpath": "/dev/mmcblk0",
        "slot_layouts": {
          "a": [
            "boot-a",
            "rootfs-a",
            "var"
          ],
          "b": [
            "boot-b",
            "rootfs-b",
            "var"
          ]
        }
      }
    ],
    "rollback": [
      {
        "type": "uboot-env",
        "set": {
          "avocado_boot_slot": "{previous_slot}"
        }
      },
      {
        "type": "mbr-switch",
        "devpath": "/dev/mmcblk0",
        "slot_layouts": {
          "a": [
            "boot-a",
            "rootfs-a",
            "var"
          ],
          "b": [
            "boot-b",
            "rootfs-b",
            "var"
          ]
        }
      }
    ]
  },
  "provision": {
    "envs": {
      "device_info": {
        "AVOCADO_DEVICE_CERT": "${AVOCADO_DEVICE_CERT}",
        "AVOCADO_DEVICE_KEY": "${AVOCADO_DEVICE_KEY}",
        "AVOCADO_DEVICE_ID": "${AVOCADO_DEVICE_ID}"
      }
    },
    "profiles": {
      "img": {
        "script": "stone-provision-img.sh",
        "envs": [
          "device_info"
        ]
      },
      "sd": {
        "script": "stone-provision-sd.sh",
        "envs": [
          "device_info"
        ],
        "requires": [
          "usb"
        ]
      },
      "usb": {
        "script": "stone-provision-usb.sh",
        "envs": [
          "device_info"
        ],
        "requires": [
          "usb"
        ]
      }
    }
  },
  "storage_devices": {
    "rootdisk": {
      "out": "avocado-raspberrypi5-rootdisk.zip",
      "build_args": {
        "type": "fwup",
        "template": "rootdisk.conf"
      },
      "devpath": "/dev/mmcblk0",
      "block_size": 512,
      "images": {
        "uboot_env": "uboot.env",
        "boot": {
          "out": "boot.img",
          "size": 128,
          "size_unit": "mebibytes",
          "build_args": {
            "type": "fat",
            "variant": "FAT32",
            "files": [
              {
                "in": "u-boot.bin",
                "out": "kernel_2712.img"
              },
              {
                "in": "bootfiles/bootcode.bin",
                "out": "bootcode.bin"
              },
              {
                "in": "bootfiles/cmdline.txt",
                "out": "cmdline.txt"
              },
              {
                "in": "bootfiles/config.txt",
                "out": "config.txt"
              },
              {
                "in": "bootfiles/fixup_cd.dat",
                "out": "fixup_cd.dat"
              },
              {
                "in": "bootfiles/fixup_db.dat",
                "out": "fixup_db.dat"
              },
              {
                "in": "bootfiles/fixup_x.dat",
                "out": "fixup_x.dat"
              },
              {
                "in": "bootfiles/fixup.dat",
                "out": "fixup.dat"
              },
              {
                "in": "bootfiles/fixup4.dat",
                "out": "fixup4.dat"
              },
              {
                "in": "bootfiles/fixup4cd.dat",
                "out": "fixup4cd.dat"
              },
              {
                "in": "bootfiles/fixup4db.dat",
                "out": "fixup4db.dat"
              },
              {
                "in": "bootfiles/fixup4x.dat",
                "out": "fixup4x.dat"
              },
              {
                "in": "bootfiles/start_cd.elf",
                "out": "start_cd.elf"
              },
              {
                "in": "bootfiles/start_db.elf",
                "out": "start_db.elf"
              },
              {
                "in": "bootfiles/start_x.elf",
                "out": "start_x.elf"
              },
              {
                "in": "bootfiles/start.elf",
                "out": "start.elf"
              },
              {
                "in": "bootfiles/start4.elf",
                "out": "start4.elf"
              },
              {
                "in": "bootfiles/start4cd.elf",
                "out": "start4cd.elf"
              },
              {
                "in": "bootfiles/start4db.elf",
                "out": "start4db.elf"
              },
              {
                "in": "bootfiles/start4x.elf",
                "out": "start4x.elf"
              },
              {
                "in": "overlay_map.dtb",
                "out": "overlays/overlay_map.dtb"
              },
              {
                "in": "bcm2712d0.dtbo",
                "out": "overlays/bcm2712d0.dtbo"
              },
              {
                "in": "vc4-kms-v3d-pi5.dtbo",
                "out": "overlays/vc4-kms-v3d-pi5.dtbo"
              },
              {
                "in": "dwc2.dtbo",
                "out": "overlays/dwc2.dtbo"
              },
              "bcm2712-rpi-5-b.dtb",
              "bcm2712-rpi-cm5-cm5io.dtb",
              "bcm2712-rpi-cm5-cm4io.dtb",
              "bcm2712-rpi-cm5l-cm5io.dtb",
              "bcm2712-rpi-cm5l-cm4io.dtb",
              "avocado-image-initramfs-raspberrypi5.cpio.zst",
              "Image"
            ]
          }
        },
        "rootfs": "avocado-image-rootfs-raspberrypi5.erofs-lz4",
        "var": "avocado-image-var-raspberrypi5.btrfs"
      },
      "partitions": [
        {
          "name": "uboot-env",
          "image": "uboot_env",
          "offset": 1,
          "offset_unit": "mebibytes",
          "offset_redundant": 1280,
          "offset_redundant_unit": "kibibytes",
          "size": 128,
          "size_unit": "kibibytes",
          "in-partition-table": "false"
        },
        {
          "name": "boot-a",
          "image": "boot",
          "offset": 2,
          "offset_unit": "mebibytes",
          "size": 128,
          "size_unit": "mebibytes"
        },
        {
          "name": "boot-b",
          "image": "",
          "size": 128,
          "size_unit": "mebibytes"
        },
        {
          "name": "recovery",
          "image": "",
          "size": 128,
          "size_unit": "mebibytes"
        },
        {
          "name": "rootfs-a",
          "image": "rootfs",
          "size": 160,
          "size_unit": "mebibytes"
        },
        {
          "name": "rootfs-b",
          "image": "",
          "size": 160,
          "size_unit": "mebibytes"
        },
        {
          "name": "var",
          "image": "var",
          "size": 2048,
          "size_unit": "mebibytes",
          "expand": "true"
        }
      ]
    }
  }
}
